# Rename all photos in the current directory based on their creation date
rename-photos() {
  exiftool "-filename<CreateDate" -d "%Y%m%d_%H%M%S%%-c.%%e" -r .
}

# Rename all videos in the current directory based on their creation date
rename-videos(){
  exiftool -api QuickTimeUTC "-filename<TrackCreateDate" -d "%Y%m%d_%H%M%S%%-c.%%e" -r .
}

# Add the specified number of hours to all the media files in the current directory
function add-hours() {
  if [ -z "$1" ] || [ -z "$2" ]; then
    echo "Usage: add-hours <hours> <file(s)>"
    return 1
  fi

  exiftool -overwrite_original -AllDates+="$1" "$2"
}

# Subtract the specified number of hours from all the media files in the current directory
function subtract-hours() {
  if [ -z "$1" ] || [ -z "$2" ]; then
    echo "Usage: subtract-hours <hours> <file(s)>"
    return 1
  fi

  exiftool -overwrite_original -AllDates-="$1" "$2"
}

# Compress a single video and automatically verify VMAF score
compress-video() {
  local input="$1"
  local crf="${2:-23}"
  local preset="${3:-slow}"
  local output_dir="$(dirname -- "$input")/crf${crf}"
  local output="$output_dir/$(basename -- "$input")"
  mkdir -p "$output_dir"
  
  ffmpeg -i "$input" -fps_mode passthrough -map_metadata 0 -c:v libx265 -preset "$preset" -crf "$crf" -c:a copy -tag:v hvc1 "$output" && \
  
  # To downsample from 10 bit to 8 bit:
  #/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg -i "$input" \
  #-vf "zscale=t=linear:npl=100,format=gbrpf32le,zscale=p=bt709,tonemap=hable:desat=0,zscale=t=bt709:m=bt709:r=tv,format=yuv420p" \
  #-c:v libx265 -preset "$preset" -crf "$crf" \
  #-c:a copy -tag:v hvc1 -map_metadata 0 "$output" && \
    exiftool -overwrite_original -P -api QuickTimeUTC -tagsFromFile "$input" \
      -All:All \
      "-QuickTime:GPSCoordinates<QuickTime:GPSCoordinates" \
      "-Keys:GPSCoordinates<Keys:GPSCoordinates" \
      "-UserData:GPSCoordinates<UserData:GPSCoordinates" \
      "-ItemList:GPSCoordinates<ItemList:GPSCoordinates" \
      "-Make<Make" \
      "-Model<Model" \
      "-AndroidMake<AndroidMake" \
      "-AndroidModel<AndroidModel" \
      "$output" && \
    echo "\nCompression complete. Running VMAF verification..." && \
    vmaf-video "$input" "$crf"
}

# Compress all videos in the current directory
compress-videos() {
  local crf="${1:-23}"
  local preset="${2:-slow}"
  for file in *.(mp4|MP4|mov|MOV|mkv|MKV)(N); do
    if [ -f "$file" ]; then
      compress-video "$file" "$crf" "$preset"
    fi
  done
}

# Compute the VMAF score of a compressed video against its original
vmaf-video() {
  local input="$1"
  local crf="${2:-23}"
  local subsample="${3:-5}"
  local cores="${4:-10}"
  local output_dir="$(dirname -- "$input")/crf${crf}"
  local output="$output_dir/$(basename -- "$input")"

  if [ ! -f "$input" ]; then
    echo "Original file not found: $input"
    return 1
  fi
  if [ ! -f "$output" ]; then
    echo "Compressed file not found: $output"
    return 1
  fi

  # Uses filter_complex to align frames sequentially (settb=1/AVTB,setpts=N) 
  # to prevent VFR timestamp drift from ruining VMAF comparisons
  ffmpeg -hwaccel videotoolbox -i "$output" -hwaccel videotoolbox -i "$input" \
    -filter_complex "[0:v]settb=1/AVTB,setpts=N[dist];[1:v]settb=1/AVTB,setpts=N[ref];[dist][ref]libvmaf=n_threads=${cores}:n_subsample=${subsample}" \
    -f null -
}

# Compute the VMAF score of all compressed videos in the current directory
vmaf-videos() {
  local crf="${1:-23}"
  local subsample="${2:-5}"
  local cores="${3:-10}"
  for file in *.(mp4|MP4|mov|MOV|mkv|MKV)(N); do
    if [ -f "$file" ]; then
      echo "VMAF score for $file (CRF $crf, Subsample $subsample, Cores $cores):"
      vmaf-video "$file" "$crf" "$subsample" "$cores"
    fi
  done
}

# Compress a single photo
compress-photo() {
  local file=$1
  local quality=${2:-75}
  mkdir -p "$(dirname -- "$file")/$quality"
  cjpeg -quality "$quality" -outfile "$(dirname -- "$file")/$quality/$(basename -- "$file")" "$file"
}

# Compress all photos in a directory, preserving the directory layout under the quality folder
compress-photos() {
  local directory="${1:-.}"
  local quality="${2:-75}"
  local cjpeg_bin="$(command -v cjpeg || true)"
  local found=0
  directory="${directory%/}"

  if [ ! -d "$directory" ]; then
    echo "Usage: compress-photos <directory> [quality]"
    return 1
  fi

  if [ -z "$cjpeg_bin" ]; then
    cjpeg_bin="/opt/homebrew/opt/mozjpeg/bin/cjpeg"
  fi

  find "$directory" \
    -path "$quality" -prune -o \
    -path "$quality/*" -prune -o \
    -path "$directory/$quality" -prune -o \
    -type f \( -iname '*.jpg' -o -iname '*.jpeg' \) -print0 |
    while IFS= read -r -d $'\0' file; do
      found=1
      local rel="${file#$directory/}"
      local output_dir="$quality/$(dirname -- "$rel")"
      mkdir -p "$output_dir"
      "$cjpeg_bin" -quality "$quality" -outfile "$output_dir/$(basename -- "$rel")" "$file"
    done

  if [ "$found" -eq 0 ]; then
    echo "No JPG/JPEG photos found under $directory."
  fi
}